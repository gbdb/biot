# Radix Sylva — copier vers .env
# SECRET_KEY=...
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# CORS_ALLOW_ALL_ORIGINS=True

# Base de données
# --- Sans ligne DATABASE_URL : SQLite (db.sqlite3) — OK pour démarrer sans Docker ---
# --- PostgreSQL (Docker Desktop : docker compose up -d, port 5433) ---
# DATABASE_URL=postgres://radixsylva:radixsylva@127.0.0.1:5433/radixsylva
# --- PostgreSQL (Homebrew, souvent port 5432) ---
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/radixsylva

# Clés API sync (séparées par virgule si plusieurs) — utilisées au Pass B
# RADIX_SYLVA_SYNC_API_KEYS=
