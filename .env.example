# Jardin bIOT - Variables d'environnement
# Copier vers .env et adapter : cp .env.example .env

# Clé secrète Django (obligatoire en production)
# Générer une nouvelle : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=your-secret-key-here

# Debug (désactiver en production)
# DEBUG=True

# Hôtes autorisés (production), séparés par des virgules
# Pour runserver 0.0.0.0:8000 (accès réseau), inclure 0.0.0.0
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,votredomaine.com

# CORS (app mobile Expo) - True en dev, False en prod si app pointe vers ce serveur
# CORS_ALLOW_ALL_ORIGINS=True

# Base de données — dev recommandé : PostgreSQL (une seule config équipe)
# 1) À la racine du repo : docker compose up -d
# 2) Décommenter la ligne suivante (port 5434 = service jardinbiot, distinct de Radix 5433)
DATABASE_URL=postgres://jardinbiot:jardinbiot@127.0.0.1:5434/jardinbiot

# Sans DATABASE_URL : SQLite (db.sqlite3) — possible mais search_vector / rebuild_search_vectors limités

# Distance de pollinisation par défaut (mètres) - fallback quand espèce et préférence utilisateur n'ont pas de valeur
# POLLINATION_DISTANCE_MAX_DEFAULT_M=50

# Cesium Ion (vue terrain 3D) — token depuis ion.cesium.com ; laisser CESIUM_LIDAR_ASSET_ID vide jusqu'à upload LiDAR
# CESIUM_ION_ACCESS_TOKEN=eyJhbGci...
# CESIUM_LIDAR_ASSET_ID=

# Radix Sylva — sync du cache botanique (commande: python manage.py sync_radixsylva)
# RADIX_SYLVA_API_URL=http://127.0.0.1:8001/api/v1
# RADIX_SYLVA_SYNC_API_KEY=   # même valeur qu'une clé dans RADIX_SYLVA_SYNC_API_KEYS côté Radix (optionnel si vide)
